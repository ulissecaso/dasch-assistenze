{
  "name": "dasch-scraper-gestionale",
  "version": "1.0.0",
  "type": "module",
  "description": "Scraper automatico Vamart: scarica commissioni di assistenza + Piano di Carico e li importa in Supabase",
  "scripts": {
    "download": "node downloadCsvGestionale.mjs",
    "pipeline": "node downloadCsvGestionale.mjs && node ../scripts/import-csv/importCommissioniAssistenza.mjs ./downloads/ultimo.csv && node ../scripts/import-csv/importVamartCsv.mjs ./downloads/ultimo-piano-di-carico.csv"
  },
  "dependencies": {
    "playwright": "^1.47.0"
  }
}
